# Primary config source is config.yaml in the repo root.
# Override the path only when you need a different file.
CONFIG_FILE=config.yaml

# Minimal runtime overrides still supported by internal/config/load.go.
PG_DSN=postgres://postgres:postgres@localhost:5432/cixing?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
SMTP_PASSWORD=
