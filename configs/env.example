# Primary config source is config.yaml in the repo root.
# Override the path only when you need a different file.
CONFIG_FILE=config.yaml

# Minimal runtime overrides still supported by internal/config/load.go.
PG_DSN=postgres://postgres:postgres@localhost:5432/cixing?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
OSS_CREDENTIAL_MODE=
OSS_ECS_ROLE_NAME=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ASSUME_ROLE_ARN=
OSS_ASSUME_ROLE_SESSION_NAME=
OSS_ASSUME_ROLE_EXTERNAL_ID=
OSS_ASSUME_ROLE_STS_ENDPOINT=
OSS_ASSUME_ROLE_SESSION_DURATION=
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
SMTP_PASSWORD=
